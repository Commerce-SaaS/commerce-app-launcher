# ==================================================================
# COMMERCE APP - ENVIRONMENT VARIABLES
# ==================================================================
# 1. Copy this file to ".env" in the same directory:
#      cp .env.example .env
# 2. Fill in every value below. Sections marked (required) must be
#    set before the stack will start; sections marked (optional)
#    can be left empty to disable that integration.
# 3. Never commit your real ".env" file.
# ==================================================================

# ===============================
# GLOBAL (required)
# ===============================
# development | production | test
NODE_ENV=development

# ===============================
# DATABASES (required)
# ===============================
# Shared Postgres credentials used by every microservice's database.
POSTGRES_USER=
POSTGRES_PASSWORD=
DB_PORT=5432

# Individual database names, one per service (defaults shown are fine to keep).
AUTH_DB=authdb
ORGANIZATION_DB=organizationdb
ORDERS_DB=ordersdb
PAYMENTS_DB=paymentsdb
PRODUCTS_DB=productsdb

# ===============================
# RABBITMQ (required)
# ===============================
RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_HOST=
RABBITMQ_PORT=
# Full connection string, e.g. amqp://<user>:<pass>@<host>:<port>
RABBITMQ_URL=

# Request/response queues (one per microservice).
RABBITMQ_QUEUE_CLIENT_GATEWAY=
RABBITMQ_QUEUE_AUTH=
RABBITMQ_QUEUE_ORGANIZATION=
RABBITMQ_QUEUE_ORDERS=
RABBITMQ_QUEUE_PAYMENTS=
RABBITMQ_QUEUE_PRODUCTS=
RABBITMQ_QUEUE_MEDIA=
RABBITMQ_QUEUE_WEBHOOKS=

# Event/pub-sub queues consumed across services.
RMQ_EVENTS_QUEUE_NOTIFICATIONS=
RMQ_EVENTS_QUEUE_ORGANIZATION=
RMQ_EVENTS_QUEUE_ORDERS=
RMQ_EVENTS_QUEUE_PAYMENTS=
RMQ_EVENTS_QUEUE_PRODUCTS=
RMQ_EVENTS_QUEUE_WEBHOOKS=
RMQ_EVENTS_QUEUE_AUTHZ=

# ===============================
# REDIS (required)
# ===============================
REDIS_HOST=
REDIS_PORT=
REDIS_PASS=

# ===============================
# JWT (required)
# ===============================
# Each secret must be a long, random string. Generate one per line with:
#   openssl rand -hex 64
# or online (use only for local/dev, never paste production secrets into a website):
#   https://generate-secret.vercel.app/64
JWT_SECRET_ACCESS=
JWT_SECRET_REFRESH=
JWT_SECRET_VERIFY_EMAIL=

# ===============================
# FRONT (required)
# ===============================
# URL of the frontend app (e.g. http://localhost:3000). Used for CORS, links in
# emails, and as the base for Stripe success/cancel/refresh redirect URLs.
CLIENT_URL=

# App branding shown in emails / client responses.
APP_NAME=
APP_URL=
LOGO_URL=

# ===============================
# GOOGLE (optional - Google Sign-In)
# ===============================
# Create an OAuth 2.0 Client ID at:
#   https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ===============================
# SMTP (optional - transactional emails)
# ===============================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ===============================
# STRIPE (optional - billing/payments)
# ===============================
# API keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET=

# Webhook signing secrets: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=

# Price IDs for subscription plans: https://dashboard.stripe.com/products
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PRO=

# ===============================
# AWS (optional - file storage)
# ===============================
# Create an IAM user with S3 access and generate keys at:
#   https://console.aws.amazon.com/iamv2/home#/users
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET=

# ===============================
# OBSERVABILITY (optional)
# ===============================
GRAFANA_PASSWORD=
